APP_NAME=Invest Alert API
APP_ENV=dev

DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@127.0.0.1:5432/DB_NAME

JWT_ALGORITHM=HS256
JWT_ACCESS_SECRET=YOUR_KEY
JWT_REFRESH_SECRET=YOUR_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

WATCHLIST_MAX_STOCKS=YOUR_NUMBER

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

MARKETAUX_API_KEY= YOUR_API_KEY
MARKETAUX_BASE_URL=https://api.marketaux.com/v1
MARKETAUX_NEWS_LANGUAGE=en
MARKETAUX_NEWS_COUNTRIES=in
MARKETAUX_NEWS_LIMIT=6
GOOGLE_NEWS_RSS_BASE_URL=https://news.google.com/rss/search
GOOGLE_NEWS_HL=en-IN
GOOGLE_NEWS_GL=IN
GOOGLE_NEWS_CEID=IN:en
GOOGLE_NEWS_LOOKBACK_DAYS=7
GOOGLE_NEWS_REQUEST_LIMIT=10

DAILY_CONTEXT_ARTICLE_LIMIT=3
ENABLE_CONTEXT_SCHEDULER=true
CONTEXT_HARVEST_HOUR=17
CONTEXT_HARVEST_MINUTE=25
CONTEXT_HARVEST_TIMEZONE=Asia/Kolkata

# Postgres-backed summary worker
ENABLE_SUMMARY_WORKER=true
SUMMARY_WORKER_INTERVAL_SECONDS=10
SUMMARY_WORKER_BATCH_SIZE=3
SUMMARY_CACHE_TTL_SECONDS=86400
SUMMARY_FETCH_TIMEOUT_SECONDS=15
SUMMARY_SENTENCE_COUNT=3
SUMMARY_MAX_INPUT_CHARS=6000
SUMMARY_EXCERPT_CHARS=320
